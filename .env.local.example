# Admin App — local environment overrides
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# URL of the Smart Queue backend.
# For local development (backend on the same PC): leave as-is or omit entirely.
# For LAN multi-PC testing: replace with the backend server's LAN IP.
#   e.g. VITE_API_URL=http://192.168.1.100:3000
VITE_API_URL=http://localhost:3000
